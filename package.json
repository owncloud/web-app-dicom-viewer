{
  "name": "web-app-dicom-viewer",
  "version": "0.0.0",
  "description": "ownCloud Web DICOM Viewer",
  "license": "AGPL-3.0",
  "type": "module",
  "scripts": {
    "lint": "eslint src --ext vue --ext js --ext ts --color",
    "build": "pnpm vite build",
    "build:w": "pnpm vite build --watch --mode development",
    "test:unit": "NODE_OPTIONS=--unhandled-rejections=throw jest --config tests/unit/config/jest.config.ts"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@ownclouders/eslint-config": "0.0.1",
    "@ownclouders/extension-sdk": "0.0.5-alpha.2",
    "@ownclouders/prettier-config": "0.0.1",
    "@ownclouders/tsconfig": "0.0.5-alpha.1",
    "@types/jest": "29.5.1",
    "@types/node": "^20.2.3",
    "@vue/test-utils": "v2.4.0-alpha.0",
    "@vue/vue3-jest": "29.2.4",
    "eslint": "8.31.0",
    "jest": "29.7.0",
    "jest-fetch-mock": "3.0.3",
    "jest-mock-extended": "3.0.4",
    "prettier": "2.6.2",
    "ts-jest": "29.1.0",
    "ts-node": "10.9.1",
    "typescript": "5.3.3",
    "vite": "5.0.8",
    "vue": "3.3.4"
  },
  "dependencies": {
    "@cornerstonejs/core": "^1.13.0",
    "@cornerstonejs/dicom-image-loader": "^1.13.0",
    "dicom-parser": "^1.8.21"
  },
  "peerDependencies": {
    "@ownclouders/web-client": "0.0.1",
    "@ownclouders/web-pkg": "0.0.5-alpha.1",
    "lodash-es": "^4.17.21",
    "luxon": "^2.4.0",
    "vue3-gettext": "^2.3.3",
    "vuex": "4.1.0"
  },
  "pnpm": {
    "overrides": {
      "mime": "^3.0.0"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "design-system*"
      ]
    }
  }
}
